---
import { type CollectionEntry, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await post.render();
---

<BaseLayout title={post.data.title} description={post.data.description}>
	<article class="pt-40 pb-20 px-6 md:px-12">
		<header class="max-w-[65ch] mx-auto mb-16">
			<div class="flex items-center gap-4 mb-8">
				<a href="/blog" class="font-mono text-[0.65rem] tracking-[0.12em] uppercase text-[var(--muted)] no-underline hover:text-[var(--ink)] transition-colors flex items-center gap-2">
					<svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
						<path d="M19 12H5M12 19l-7-7 7-7"/>
					</svg>
					Voltar ao Blog
				</a>
				<span class="w-8 h-[1px] bg-[var(--border)]"></span>
				<span class="font-mono text-[0.65rem] tracking-[0.12em] uppercase text-[var(--accent)]">
					{post.data.pubDate.toLocaleDateString('pt', { year: 'numeric', month: 'long', day: 'numeric' })}
				</span>
			</div>
			
			<h1 class="font-serif text-[clamp(2.5rem,5vw,4rem)] font-bold leading-[1.1] tracking-tight mb-8">
				{post.data.title}
			</h1>
			
			<p class="text-[1.1rem] leading-[1.8] text-[var(--muted)] border-l-2 border-[var(--accent)] pl-6 italic">
				{post.data.description}
			</p>
		</header>

		{post.data.heroImage && (
			<div class="max-w-5xl mx-auto mb-16 aspect-[21/9] overflow-hidden border border-[var(--border)]">
				<img src={post.data.heroImage} alt="" class="w-full h-full object-cover" />
			</div>
		)}

		<div class="prose prose-premium mx-auto">
			<Content />
		</div>

		<footer class="max-w-[65ch] mx-auto mt-20 pt-12 border-t border-[var(--border)]">
			<div class="bg-[var(--ink)] text-[var(--paper)] p-8 md:p-12">
				<h3 class="font-serif text-[1.5rem] font-bold mb-4 italic">Interessado em escalar o seu ecossistema digital?</h3>
				<p class="text-[0.9rem] leading-[1.7] opacity-60 mb-8">Especialista em Django e Flutter, foco em arquitecturas de alta disponibilidade para mercados africanos.</p>
				<a href="/#contacto" class="font-mono text-[0.72rem] tracking-[0.12em] uppercase bg-[var(--accent)] text-[var(--ink)] px-6 py-3 no-underline inline-block hover:bg-[var(--paper)] transition-all duration-300">
					Solicitar Consultoria
				</a>
			</div>
		</footer>
	</article>
</BaseLayout>

<style is:global>
	.prose-premium {
		font-family: var(--sans);
		font-size: 1.05rem;
		line-height: 1.85;
		color: var(--ink);
	}
	.prose-premium h2 { @apply font-serif text-[2.2rem] font-bold mt-16 mb-8 leading-tight; }
	.prose-premium h3 { @apply font-serif text-[1.6rem] font-bold mt-12 mb-6 leading-tight; }
	.prose-premium p { @apply mb-8 opacity-85; }
	.prose-premium strong { @apply font-bold text-[var(--ink)]; }
	.prose-premium code { @apply font-mono bg-black/5 px-2 py-1 rounded text-sm; }
	.prose-premium blockquote { @apply border-l-2 border-[var(--accent2)] pl-6 italic text-[var(--muted)] my-12; }
</style>
